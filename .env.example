# Premium Purchase Verification Configuration
# Copy this to .env.local for local testing or set in Vercel Dashboard

# ============================================
# SUPABASE DATABASE (Required for webhook system)
# Get these from https://supabase.com/dashboard
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# GUMROAD WEBHOOK - Automatically add buyers to premium list
# Webhook URL: https://your-app.vercel.app/api/gumroad-webhook
# Set this in Gumroad: Settings > Advanced > Webhooks
# ============================================

# Option 1: Manual email list (simplest for small scale)
# Comma-separated list of emails that have purchased premium
VERIFIED_PREMIUM_EMAILS=purchaser1@example.com,purchaser2@example.com,purchaser3@example.com

# Option 2: Gumroad API Integration (for automated verification)
# Get your access token from: https://app.gumroad.com/settings/developer
GUMROAD_ACCESS_TOKEN=your_gumroad_access_token_here

# Your Gumroad product ID (found in product URL or via API)
GUMROAD_PRODUCT_ID=your_product_id_here

# Example product ID format: DdDDeEeEeEeEeEeEeEeEeEeEeE
# Get it from your Gumroad product URL: gumroad.com/l/PRODUCT_ID
